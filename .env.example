# FlairAi Backend Environment Configuration
# Copy this file to .env and fill in the values

# ================================
# Application Settings
# ================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ================================
# Security Settings
# ================================
# Generate a strong JWT secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here-minimum-32-characters

# ================================
# Supabase Configuration
# ================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ================================
# Google Gemini AI (Optional)
# ================================
GEMINI_API_KEY=your-gemini-api-key

# ================================
# File Upload Settings
# ================================
UPLOAD_MAX_SIZE=10mb
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ================================
# Rate Limiting
# ================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ================================
# Database Settings
# ================================
# For direct database connections (if needed)
DATABASE_URL=postgresql://user:password@localhost:5432/flaire_ai

# ================================
# External Services
# ================================
# Email service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ================================
# Cloud Storage (Google Cloud)
# ================================
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_BUCKET_NAME=flaire-ai-storage
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ================================
# Monitoring & Analytics
# ================================
# Sentry for error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics
GA_TRACKING_ID=UA-XXXXXXXXX-X

# ================================
# Logging Settings
# ================================
LOG_LEVEL=info

# ================================
# Multi-tenant Settings
# ================================
ENABLE_MULTI_TENANT=true
DEFAULT_TENANT_PLAN=starter

# ================================
# Development Settings
# ================================
# Enable debug mode
DEBUG_MODE=true

# Disable authentication for development (NOT for production)
DISABLE_AUTH=false

# Mock external services
MOCK_EXTERNAL_SERVICES=false