# FlairAi Production Environment Configuration
# This file contains production environment variables

# ================================
# Application Settings
# ================================
NODE_ENV=production
PORT=8080
FRONTEND_URL=https://flareai.app

# ================================
# Security Settings
# ================================
# Strong JWT secret (minimum 32 characters)
JWT_SECRET=${JWT_SECRET}

# ================================
# Supabase Configuration
# ================================
SUPABASE_URL=${SUPABASE_URL}
SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SUPABASE_SERVICE_ROLE_KEY}

# ================================
# Google Gemini AI
# ================================
GEMINI_API_KEY=${GEMINI_API_KEY}

# ================================
# File Upload Settings
# ================================
UPLOAD_MAX_SIZE=50mb
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4

# ================================
# Rate Limiting (More restrictive in production)
# ================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50

# ================================
# Database Settings
# ================================
DATABASE_URL=${DATABASE_URL}

# ================================
# External Services
# ================================
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USER=${SMTP_USER}
SMTP_PASS=${SMTP_PASS}

# ================================
# Google Cloud Settings
# ================================
GOOGLE_CLOUD_PROJECT_ID=${GOOGLE_CLOUD_PROJECT_ID}
GOOGLE_CLOUD_BUCKET_NAME=${GOOGLE_CLOUD_BUCKET_NAME}
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json

# ================================
# Monitoring & Analytics
# ================================
SENTRY_DSN=${SENTRY_DSN}
GA_TRACKING_ID=${GA_TRACKING_ID}

# ================================
# Logging Settings
# ================================
LOG_LEVEL=info

# ================================
# Multi-tenant Settings
# ================================
ENABLE_MULTI_TENANT=true
DEFAULT_TENANT_PLAN=starter

# ================================
# Production Settings
# ================================
DEBUG_MODE=false
DISABLE_AUTH=false
MOCK_EXTERNAL_SERVICES=false

# ================================
# Performance Settings
# ================================
CLUSTER_WORKERS=auto
MEMORY_LIMIT=1024
CPU_LIMIT=1000

# ================================
# Security Headers
# ================================
ENABLE_HSTS=true
ENABLE_CSP=true
ENABLE_RATE_LIMITING=true